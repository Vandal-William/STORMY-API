# ============================================================
# Message Service Configuration (.env.example)
# ============================================================
# Copy this file to .env and adjust the values for your environment

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=3001
HOST=0.0.0.0

# ============================================================
# CASSANDRA CONFIGURATION
# ============================================================
# Cassandra contact points (comma-separated if multiple)
CASSANDRA_HOSTS=localhost

# Cassandra port (default: 9042)
CASSANDRA_PORT=9042

# Keyspace name (default: message_service)
CASSANDRA_KEYSPACE=message_service

# Cassandra authentication (optional)
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=

# Cassandra consistency level (ONE, LOCAL_ONE, QUORUM, LOCAL_QUORUM, etc.)
CASSANDRA_CONSISTENCY=LOCAL_ONE

# Cassandra connection timeouts (in seconds)
CASSANDRA_TIMEOUT=10
CASSANDRA_CONNECT_TIMEOUT=10

# Cassandra replication factor for keyspace creation
CASSANDRA_REPLICATION_FACTOR=1

# ============================================================
# REDIS CONFIGURATION
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
# NATS CONFIGURATION
# ============================================================
NATS_URL=nats://localhost:4222

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Request logging level
LOG_LEVEL=info

# Enable request tracing
ENABLE_TRACING=false

# OpenTelemetry endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
