	// Write to secondary (In-Memory) - best effort
	go func() {
		if err := d.secondary.Create(ctx, msg); err != nil {
			log.Printf("Warning: secondary write failed: %v", err)
		}
	}()

	return result, nil
}

func (d *DualWriteRepository) GetByID(ctx context.Context, id gocql.UUID) (*domain.Message, error) {
