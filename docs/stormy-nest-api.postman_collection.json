            "body": { "mode": "raw", "raw": "{\n  \"reporterId\": \"{{userId}}\",\n  \"reportedUserId\": \"{{user2Id}}\",\n  \"reason\": \"spam\",\n  \"description\": \"Envoi de spam dans le groupe\"\n}" },
            "url": { "raw": "{{moderationServiceUrl}}/reports", "host": ["{{moderationServiceUrl}}"], "path": ["reports"] }
          }
