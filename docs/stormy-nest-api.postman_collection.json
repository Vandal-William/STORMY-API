{
  "info": {
    "name": "Stormy - Nest API",
    "description": "Collection complète de tous les services NestJS : User Service (Auth, Profile, Contacts, Blocked), Moderation Service (Reports, Bans) et Notification Service (Notifications, Settings)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "userServiceUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "moderationServiceUrl", "value": "http://localhost:3004", "type": "string" },
    { "key": "notificationServiceUrl", "value": "http://localhost:3003", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "user2Id", "value": "", "type": "string" },
    { "key": "contactId", "value": "", "type": "string" },
    { "key": "blockedId", "value": "", "type": "string" },
    { "key": "reportId", "value": "", "type": "string" },
    { "key": "banId", "value": "", "type": "string" },
    { "key": "notificationId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "User Service - Auth",
      "description": "Authentification (port 3000) - Register, Login, Refresh, Logout",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Message registered', () => pm.expect(pm.response.json().message).to.eql('registered'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"0612345678\",\n  \"username\": \"testuser\",\n  \"password\": \"Password1@\",\n  \"email\": \"test@mail.com\"\n}" },
            "url": { "raw": "{{userServiceUrl}}/auth/register", "host": ["{{userServiceUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Register User 2 (for contacts tests)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"0698765432\",\n  \"username\": \"user2\",\n  \"password\": \"Password1@\"\n}" },
            "url": { "raw": "{{userServiceUrl}}/auth/register", "host": ["{{userServiceUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Message logged in', () => pm.expect(pm.response.json().message).to.eql('logged in'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"Password1@\"\n}" },
            "url": { "raw": "{{userServiceUrl}}/auth/login", "host": ["{{userServiceUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "url": { "raw": "{{userServiceUrl}}/auth/refresh", "host": ["{{userServiceUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Get Auth Me",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has username', () => pm.expect(pm.response.json()).to.have.property('username'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{userServiceUrl}}/auth/me", "host": ["{{userServiceUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST",
            "url": { "raw": "{{userServiceUrl}}/auth/logout", "host": ["{{userServiceUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "User Service - Profile",
      "description": "Gestion du profil (port 3000) - CRUD profil utilisateur",
      "item": [
        {
          "name": "Get My Profile",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has full profile fields', () => {",
            "  pm.expect(json).to.have.property('id');",
            "  pm.expect(json).to.have.property('phone');",
            "  pm.expect(json).to.have.property('username');",
            "});",
            "pm.test('No passwordHash', () => pm.expect(json).to.not.have.property('passwordHash'));",
            "pm.collectionVariables.set('userId', json.id);"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{userServiceUrl}}/profile/me", "host": ["{{userServiceUrl}}"], "path": ["profile", "me"] }
          }
        },
        {
          "name": "Update My Profile",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('About updated', () => pm.expect(pm.response.json().about).to.eql('Hello Stormy'));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"about\": \"Hello Stormy\"\n}" },
            "url": { "raw": "{{userServiceUrl}}/profile/me", "host": ["{{userServiceUrl}}"], "path": ["profile", "me"] }
          }
        },
        {
          "name": "Search Users",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has pagination', () => {",
            "  pm.expect(json).to.have.property('data');",
            "  pm.expect(json).to.have.property('total');",
            "  pm.expect(json).to.have.property('totalPages');",
            "});",
            "if (json.data.length > 0) {",
            "  const user2 = json.data.find(u => u.username === 'user2');",
            "  if (user2) pm.collectionVariables.set('user2Id', user2.id);",
            "}"
          ]}}],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{userServiceUrl}}/profile/search?username=user2",
              "host": ["{{userServiceUrl}}"], "path": ["profile", "search"],
              "query": [{ "key": "username", "value": "user2" }]
            }
          }
        },
        {
          "name": "Get User By ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Public profile only', () => {",
            "  pm.expect(json).to.have.property('username');",
            "  pm.expect(json).to.not.have.property('email');",
            "  pm.expect(json).to.not.have.property('phone');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": { "raw": "{{userServiceUrl}}/profile/{{user2Id}}", "host": ["{{userServiceUrl}}"], "path": ["profile", "{{user2Id}}"] }
          }
        },
        {
          "name": "Delete My Account",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Deleted', () => pm.expect(pm.response.json().deleted).to.eql(true));"
          ]}}],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{userServiceUrl}}/profile/me", "host": ["{{userServiceUrl}}"], "path": ["profile", "me"] }
          }
        }
      ]
    },
    {
