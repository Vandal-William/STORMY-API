          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{user2Id}}\",\n  \"reason\": \"Spam repetitif\",\n  \"expiresAt\": \"2026-12-31T23:59:59.000Z\"\n}" },
            "url": { "raw": "{{moderationServiceUrl}}/bans", "host": ["{{moderationServiceUrl}}"], "path": ["bans"] }
