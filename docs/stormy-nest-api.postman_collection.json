    {
      "name": "Moderation Service - User Bans",
      "description": "Bannissements (port 3004) - CRUD bans",
      "item": [
        {
          "name": "Ban User (temporary)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test('Has expiresAt', () => pm.expect(json.expiresAt).to.not.be.null);",
            "pm.collectionVariables.set('banId', json.id);"
